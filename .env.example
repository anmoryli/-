# ============================================
# 孕期宝 · 环境变量配置
# ============================================
# 使用方法：
#   cp .env.example .env
#   然后填写下面的真实值
# ============================================

# ==========================================
# 数据库 (MySQL)
# ==========================================
MYSQL_HOST=175.24.205.213
MYSQL_PORT=3306
MYSQL_USER=username
MYSQL_PASSWORD=你的MySQL密码
MYSQL_DATABASE=yunfu

# ==========================================
# Redis
# ==========================================
REDIS_HOST=175.24.205.213
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# AI 模型
# ==========================================
# OpenAI 兼容 API（对话/意图识别/健康分析等）
OPENAI_API_KEY=你的API密钥
OPENAI_BASE_URL=https://api.xty.app

# 通义万相（图生图）
DASHSCOPE_API_KEY=

# ==========================================
# 阿里云 OSS（文件存储）
# ==========================================
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=你的OSS_AccessKeyId
OSS_ACCESS_KEY_SECRET=你的OSS_AccessKeySecret
OSS_BUCKET_NAME=cangqion-delong

# ==========================================
# 邮件
# ==========================================
MAIL_USERNAME=anmory@qq.com
MAIL_PASSWORD=你的邮箱授权码

# ==========================================
# 安全
# ==========================================
AES_KEY=0123456789abcdef0123456789abcdef
AES_IV=abcdef9876543210

# ==========================================
# 管理后台
# ==========================================
ADMIN_PASSWORD=
FLASK_SECRET_KEY=yunqibao-admin-secret

# ==========================================
# 端口（可选，不改就用默认值）
# ==========================================
BACKEND_PORT=9677
FRONTEND_PORT=3000
ADMIN_PORT=5000
NGINX_PORT=80
